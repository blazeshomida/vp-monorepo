{
  "name": "vp-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:vanilla": "vp run task:vanilla:build",
    "changeset": "changeset",
    "check": "vp run task:workspace:check",
    "dev:library": "vp run task:library:dev",
    "dev:vanilla": "vp run task:vanilla:dev",
